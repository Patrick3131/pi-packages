{
  "name": "pi-packages",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Pi extensions",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "clean": "npm run clean --workspaces && rm -rf node_modules coverage"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "coding-agent"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
