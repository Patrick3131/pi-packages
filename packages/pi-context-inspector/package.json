  "description": "Pi extension that inspects the effective system prompt and context burden, exporting HTML and JSON reports",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "context",
    "prompt",
    "inspector"
  ],
  "author": "Patrick Fischer <patrick-fischer@live.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Patrick3131/pi-packages",
    "directory": "packages/pi-context-inspector"
  },
  "bugs": {
    "url": "https://github.com/Patrick3131/pi-packages/issues"
  },
  "homepage": "https://github.com/Patrick3131/pi-packages#readme",
  "files": [
    "src",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "gpt-tokenizer": "^3.4.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
