# pi-crawl4ai Configuration
# Copy this file to .env or use a JSON config file (recommended)

# ============================================
# JSON CONFIG (RECOMMENDED)
# ============================================
# Create a JSON config file instead of env vars:
#
# Option 1: Project-level config
#   .pi/crawl4ai.json
#
# Option 2: Global config
#   ~/.pi/agent/extensions/crawl4ai.json
#
# Example JSON config:
# {
#   "url": "http://localhost:11235",
#   "timeoutMs": 60000,
#   "proxy": {
#     "url": "http://user:pass@proxy.example.com:8080"
#   },
#   "tools": ["crawl"]
# }
#
# Or with provider-specific proxy:
# {
#   "url": "http://localhost:11235",
#   "proxy": {
#     "provider": "oxylabs",
#     "username": "your_username",
#     "password": "your_password",
#     "host": "pr.oxylabs.io",
#     "port": 7777
#   }
# }

# ============================================
# ENVIRONMENT VARIABLES (FALLBACK)
# ============================================

# REQUIRED: crawl4ai Docker API URL or remote API URL
CRAWL4AI_BASE_URL=http://localhost:11235

# OPTIONAL: Request timeout in milliseconds
# CRAWL4AI_TIMEOUT=60000

# ============================================
# PROXY OPTIONS (ENV VARS)
# ============================================

# Option 1: Full proxy URL with authentication
# Format: http://username:password@host:port
# CRAWL4AI_PROXY_URL=http://user:pass@proxy.example.com:8080

# Option 2: Oxylabs ISP proxy (auto-configured)
# If both PROXY_URL and OXYLABS_* are set, PROXY_URL takes precedence
# OXYLABS_USER=your_username
# OXYLABS_PASS=your_password
# OXYLABS_HOST=pr.oxylabs.io
# OXYLABS_PORT=7777
