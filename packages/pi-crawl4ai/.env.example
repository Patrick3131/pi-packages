# pi-crawl4ai Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED
# ============================================

# crawl4ai Docker API URL
CRAWL4AI_BASE_URL=http://localhost:11235

# ============================================
# OPTIONAL - Proxy Configuration
# ============================================

# Request timeout in milliseconds (default: 60000)
# CRAWL4AI_TIMEOUT=60000

# Proxy Option 1: Full proxy URL with authentication
# Format: http://username:password@host:port
# CRAWL4AI_PROXY_URL=http://user:pass@proxy.example.com:8080

# Proxy Option 2: Oxylabs ISP proxy (auto-configured)
# If both PROXY_URL and OXYLABS_* are set, PROXY_URL takes precedence
# OXYLABS_USER=your_username
# OXYLABS_PASS=your_password
# OXYLABS_HOST=pr.oxylabs.io
# OXYLABS_PORT=7777
