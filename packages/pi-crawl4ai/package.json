{
  "name": "pi-crawl4ai",
  "version": "0.1.0",
  "description": "Pi extension for web crawling with crawl4ai and proxy support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --out-dir dist",
    "dev": "tsup src/index.ts --dts --format esm --out-dir dist --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf dist coverage"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "crawl4ai",
    "web-crawling",
    "scraper",
    "proxy"
  ],
  "author": "Patrick Fischer <patrick-fischer@live.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Patrick3131/pi-packages",
    "directory": "packages/pi-crawl4ai"
  },
  "bugs": {
    "url": "https://github.com/Patrick3131/pi-packages/issues"
  },
  "homepage": "https://github.com/Patrick3131/pi-packages#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.1.0"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "@sinclair/typebox": "^0.34.0",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
